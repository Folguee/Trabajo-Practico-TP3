rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{documentId} {
      // Cada usuario solo accede a su propio documento, identificado por el ID
      // (el ID del documento es el uid). No dependemos de campos internos para
      // que funcione también con documentos legacy sin el campo `uid`.
      allow create: if signedIn() && documentId == request.auth.uid;
      allow read, update, delete: if signedIn() && documentId == request.auth.uid;
    }

    match /publicUsers/{documentId} { 
      allow read: if signedIn();
      allow create, update: if signedIn()
        && documentId == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll([
          'uid',
          'nombre',
          'nombreLower',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /transactions/{documentId} {
      function isParticipant(data) {
        return signedIn()
          && request.auth.uid in data.participantUids;
      }

      function validSharedCreate() {
        return request.resource.data.type == 'shared'
          && request.resource.data.creatorUid == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.participantUids is list
          && request.auth.uid in request.resource.data.participantUids
          && request.resource.data.payerUid in request.resource.data.participantUids;
      }

      allow create: if ownsIncomingDocument()
        && (request.resource.data.type != 'shared' || validSharedCreate());
      allow read: if ownsExistingDocument() || isParticipant(resource.data);
      allow delete: if signedIn()
        && (resource.data.creatorUid == request.auth.uid
          || (!('creatorUid' in resource.data)
            && resource.data.userId == request.auth.uid));
      allow update: if signedIn()
        && (resource.data.creatorUid == request.auth.uid
          || (!('creatorUid' in resource.data)
            && resource.data.userId == request.auth.uid))
        && request.resource.data.userId == resource.data.userId
        && (
          (!('creatorUid' in resource.data)
            && (!('creatorUid' in request.resource.data)
              || request.resource.data.creatorUid == request.auth.uid))
          || (!('creatorUid' in request.resource.data)
            && resource.data.creatorUid == request.auth.uid)
          || request.resource.data.creatorUid == resource.data.creatorUid
        )
        && (request.resource.data.type != 'shared'
          || (request.resource.data.participantUids is list
            && request.resource.data.creatorUid in request.resource.data.participantUids
            && request.resource.data.payerUid in request.resource.data.participantUids));
    }

    match /categories/{documentId} {
      allow create: if ownsIncomingDocument();
      allow read, delete: if ownsExistingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }
  }
}
